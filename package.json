{
  "name": "vocavault",
  "version": "0.1.0",
  "description": "Master your vocabulary with AI-powered focus.",
  "author": "VocaVault Team",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "electron:dev": "electron .",
    "electron:build": "npx prisma db push && npm run build && node scripts/prepare-standalone.js && electron-builder"
  },
  "build": {
    "appId": "com.vocavault.app",
    "productName": "VocaVault",
    "directories": {
      "output": "dist",
      "app": "."
    },
    "files": [
      "package.json",
      "electron/**/*",
      "public/**/*",
      ".next/static/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma",
        "filter": [
          "schema.prisma",
          "dev.db"
        ]
      },
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/node_modules/prisma/**/*",
      "**/node_modules/@prisma/client/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "lucide-react": "^0.358.0",
    "next": "14.1.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8",
    "eslint-config-next": "14.1.3",
    "postcss": "^8",
    "prisma": "^5.10.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
