// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Topic {
  id          String   @id @default(cuid())
  name        String
  description String?
  words       Word[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Word {
  id           String   @id @default(cuid())
  word         String
  definition   String
  example      String?
  topicId      String
  topic        Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  
  // 학습 통계 및 SRS 필드
  correctCount Int      @default(0)
  missedCount  Int      @default(0)
  interval     Int      @default(0)      // 현재 복습 간격 (단위: 일)
  easeFactor   Float    @default(2.5)    // 난이도 가중치 (기본값 2.5)
  nextReviewAt DateTime @default(now())  // 다음 복습 예정 일시
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserStats {
  id               String   @id @default("global-stats")
  totalExp         Int      @default(0)
  level            Int      @default(1)
  wordsAdded       Int      @default(0)
  quizzesCompleted Int      @default(0)
  updatedAt        DateTime @updatedAt
}
